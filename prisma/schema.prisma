generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Institute {
  id             String    @id @default(cuid())
  name           String
  logo           String?
  primaryColor   String    @default("#ff6600")
  secondaryColor String    @default("#1a1a1a")
  domain         String    @unique
  createdAt      DateTime  @default(now())
  students       Student[]
}

model Student {
  id          String         @id @default(cuid())
  name        String
  contact     String         @unique
  whatsapp    String?
  email       String?        @unique
  password    String?
  instituteId String?
  createdAt   DateTime       @default(now())
  institute   Institute?     @relation(fields: [instituteId], references: [id])
  results     TypingResult[]
}

model TypingParagraph {
  id         String   @id @default(cuid())
  language   String
  difficulty String
  content    String
  createdAt  DateTime @default(now())
}

model TypingResult {
  id        String   @id @default(cuid())
  studentId String
  language  String
  wpm       Float
  accuracy  Float
  errors    Int
  duration  Int
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
}
